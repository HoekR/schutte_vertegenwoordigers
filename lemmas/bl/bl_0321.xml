<lemma schuttenr="321" corpus="bl" name="Kotzebue" givenname="Johann Ferdinand" beginjaar="1696" eindjaar="1697" functie="legatiesecretaris" category="Brunswijk-Lünenburg-Calenberg/Hannover" url="http://resources.huygens.knaw.nl/retroapp/service_schutte/service_schutte/schutte_1/html/schutte_buitenlandsevertegenwoordigersinnederland_0295.html">
  <line type="loopbaan">321. Johann Ferdinand Kotzebue, wordt als legatiesecretaris van</line>
  <line type="loopbaan">Brunswijk-Lünenburg-Calenberg het eerst vermeld 25 okt.-4</line>
  <line type="loopbaan">nov. 1696 en zond zijn laatste bericht in juni 1697; ontving</line>
  <line type="loopbaan">instructie als resident te Frankfort 27 maart 1701 en zond</line>
  <line type="loopbaan">zijn laatste bericht 23 aug. 1701.</line>
</lemma>
