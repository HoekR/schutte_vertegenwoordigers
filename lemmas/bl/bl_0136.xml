<lemma schuttenr="136" corpus="bl" name="Halloy" givenname="Andreas Johannes" beginjaar="1739" eindjaar="1741" functie="secretaris" category="De Keizer en Oostenrijk" url="http://resources.huygens.knaw.nl/retroapp/service_schutte/service_schutte/schutte_1/html/schutte_buitenlandsevertegenwoordigersinnederland_0160.html">
  <line type="loopbaan">136. Andreas Johannes (of Josephus?) (de) Halloy wordt sedert</line>
  <line type="hoofd">1736 vermeld als secretaris van Ulfeld, nr. 135, en was chargé</line>
  <line type="loopbaan">d'affaires vanaf diens vertrek in juli 1739 en zond nog een</line>
  <line type="loopbaan">bericht 7 maart 1741.</line>
  <line type="loopbaan">1742-1751(?) resident</line>
  <line type="loopbaan">Petrus van Elsacker, nr. 156.</line>
</lemma>
